{
  "name": "premium-footwear-ad60",
  "private": true,
  "type": "module",
  "scripts": {
    "assets": "node scripts/generate-premium-assets.mjs",
    "preview:hyperframes": "npx --yes hyperframes@0.6.6 preview src/hyperframes",
    "check:hyperframes": "npx --yes hyperframes@0.6.6 lint src/hyperframes && npx --yes hyperframes@0.6.6 validate src/hyperframes && npx --yes hyperframes@0.6.6 inspect src/hyperframes --samples 16",
    "render:social": "npx --yes hyperframes@0.6.6 render src/hyperframes --output renders/eter-premium-footwear-hyperframes-social.mp4 --quality standard --fps 30 --workers 1",
    "render:social:draft": "npx --yes hyperframes@0.6.6 render src/hyperframes --output renders/eter-premium-footwear-hyperframes-review.mp4 --quality draft --fps 30 --workers 1",
    "render:master": "npx --yes hyperframes@0.6.6 render src/hyperframes-4k --output renders/eter-premium-footwear-hyperframes-master-4k.mp4 --quality high --fps 60 --workers 1"
  },
  "dependencies": {
    "@remotion/cli": "4.0.459",
    "@remotion/media-utils": "4.0.459",
    "remotion": "4.0.459",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "typescript": "5.7.3"
  }
}
